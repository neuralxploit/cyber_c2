# CYBER C2 - Hacker Shell Config
# ================================

# Path to Oh My Zsh
export ZSH="$HOME/.oh-my-zsh"

# Theme - Powerlevel10k (cyberpunk style)
ZSH_THEME="powerlevel10k/powerlevel10k"

# Plugins
plugins=(
    git
    zsh-autosuggestions
    zsh-syntax-highlighting
    colored-man-pages
    command-not-found
    sudo                    # Press ESC twice to add sudo
    web-search              # google something from terminal
    copypath                # Copy current path
    copyfile                # Copy file contents
    history
)

source $ZSH/oh-my-zsh.sh

# ============================================
# ūüĒī CYBER COLOR SCHEME
# ============================================

# Custom colors (red/cyan/green hacker aesthetic)
export TERM="xterm-256color"

# LS colors - cyber style
export LS_COLORS="di=1;36:ln=35:so=32:pi=33:ex=1;31:bd=34;46:cd=34;43:su=30;41:sg=30;46:tw=30;42:ow=30;43"

# Grep colors
export GREP_COLOR='1;31'  # Red matches

# Man pages colors
export LESS_TERMCAP_mb=$'\e[1;31m'      # begin bold - red
export LESS_TERMCAP_md=$'\e[1;36m'      # begin blink - cyan
export LESS_TERMCAP_me=$'\e[0m'         # end mode
export LESS_TERMCAP_se=$'\e[0m'         # end standout
export LESS_TERMCAP_so=$'\e[1;33;41m'   # begin standout - yellow on red
export LESS_TERMCAP_ue=$'\e[0m'         # end underline
export LESS_TERMCAP_us=$'\e[1;32m'      # begin underline - green

# ============================================
# ūüĒī CYBER ALIASES
# ============================================

# Navigation
alias ..='cd ..'
alias ...='cd ../..'
alias ll='ls -alF --color=auto'
alias la='ls -A --color=auto'
alias l='ls -CF --color=auto'

# C2 shortcuts
alias c2='cd ~/cyber_c2'
alias c2start='cd ~/cyber_c2 && ./start_c5.sh'
alias c2tor='cd ~/cyber_c2 && ./start_c5.sh --tor'
alias c2log='tail -f ~/cyber_c2/cyber_c2.log'
alias c2status='ps aux | grep -E "python main|cloudflared|tor" | grep -v grep'

# Network
alias myip='curl -s https://api.ipify.org && echo ""'
alias torip='curl -s --socks5-hostname 127.0.0.1:9050 https://check.torproject.org/api/ip'
alias ports='sudo netstat -tulpn'
alias listen='sudo lsof -i -P -n | grep LISTEN'

# Security
alias vpnstatus='ip link show | grep -E "nordlynx|tun|wg"'
alias torstatus='pgrep -x tor && echo "‚úď Tor running" || echo "‚úó Tor stopped"'
alias opsec='vpnstatus; torstatus; myip'

# Git
alias gs='git status'
alias ga='git add'
alias gc='git commit -m'
alias gp='git push'

# System
alias cls='clear'
alias h='history'
alias path='echo -e ${PATH//:/\\n}'
alias now='date +"%Y-%m-%d %H:%M:%S"'

# Python
alias py='python3'
alias venv='source venv/bin/activate'
alias pip='pip3'

# Danger zone (ask for confirmation)
alias rm='rm -i'
alias mv='mv -i'
alias cp='cp -i'

# ============================================
# ūüĒī CUSTOM FUNCTIONS
# ============================================

# Quick HTTP server
serve() {
    local port="${1:-8080}"
    echo -e "\033[1;32m[*] Serving on http://0.0.0.0:$port\033[0m"
    python3 -m http.server "$port"
}

# Quick listener
listen_nc() {
    local port="${1:-4444}"
    echo -e "\033[1;31m[*] Listening on port $port...\033[0m"
    nc -lvnp "$port"
}

# Base64 encode/decode
b64e() { echo -n "$1" | base64; }
b64d() { echo -n "$1" | base64 -d; }

# URL encode/decode
urle() { python3 -c "import urllib.parse; print(urllib.parse.quote('$1'))"; }
urld() { python3 -c "import urllib.parse; print(urllib.parse.unquote('$1'))"; }

# Extract any archive
extract() {
    if [ -f "$1" ]; then
        case "$1" in
            *.tar.bz2) tar xjf "$1" ;;
            *.tar.gz)  tar xzf "$1" ;;
            *.bz2)     bunzip2 "$1" ;;
            *.gz)      gunzip "$1" ;;
            *.tar)     tar xf "$1" ;;
            *.tbz2)    tar xjf "$1" ;;
            *.tgz)     tar xzf "$1" ;;
            *.zip)     unzip "$1" ;;
            *.7z)      7z x "$1" ;;
            *)         echo "'$1' cannot be extracted" ;;
        esac
    else
        echo "'$1' is not a file"
    fi
}

