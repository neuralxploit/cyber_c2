# Show banner on startup
cyber_banner

# ============================================
# PATH
# ============================================
export PATH="$HOME/.local/bin:$HOME/go/bin:$PATH"

# Cargo/Rust
[ -f "$HOME/.cargo/env" ] && source "$HOME/.cargo/env"

# NVM (if installed)
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
