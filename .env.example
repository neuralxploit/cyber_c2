# ============================================================================
# CYBER C2 - Configuration
# ============================================================================
# Copy this to .env and fill in your values:  cp .env.example .env
#
# NOTE: start_c5.sh auto-generates PAYLOAD_TOKEN, AGENT_API_KEY, and
# A2A_JWT_SECRET on each launch and injects them into this file AND into
# payload source files (agent.rs, .ps1, .cs) before building.
# You can set your own values here — if they exist, start_c5.sh will
# keep them. Otherwise it generates fresh ones.

# Server
PORT=8000
HOST=0.0.0.0

# Metasploit RPC
MSF_HOST=127.0.0.1
MSF_PORT=55553
MSF_PASSWORD=msf
MSF_SSL=true

# JWT Secret (generate your own: openssl rand -hex 64)
JWT_SECRET=CHANGE_ME

# Redis
REDIS_URL=redis://localhost:6379/0

# Ollama AI Configuration
# OLLAMA_BASE_URL - Ollama API endpoint
# OLLAMA_MODEL - Leave empty to auto-detect first installed model from Ollama
#   Install any model: ollama pull llama3.1 / mistral / qwen2.5 / etc.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=

# Agent/Payload Auth Tokens
# These are used by payloads to authenticate back to the C2 server.
# start_c5.sh auto-generates these if not set. You can also set your own:
#   openssl rand -hex 16  (for PAYLOAD_TOKEN and AGENT_API_KEY)
#   openssl rand -hex 32  (for A2A_JWT_SECRET)
A2A_JWT_SECRET=
AGENT_API_KEY=
PAYLOAD_TOKEN=
